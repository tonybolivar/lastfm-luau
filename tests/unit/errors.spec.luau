--!strict
local Framework = require("../Framework")
local Errors = require("@self/Errors")

return function()
	Framework.describe("Errors.FromApiCode", function()
		Framework.it("maps code 6 -> InvalidParameter", function()
			Framework.expect(Errors.FromApiCode(6, "x").Kind).toBe("InvalidParameter")
		end)
		Framework.it("maps code 9 -> AuthRequired", function()
			Framework.expect(Errors.FromApiCode(9, "x").Kind).toBe("AuthRequired")
		end)
		Framework.it("maps code 10 and 26 -> InvalidApiKey", function()
			Framework.expect(Errors.FromApiCode(10, "x").Kind).toBe("InvalidApiKey")
			Framework.expect(Errors.FromApiCode(26, "x").Kind).toBe("InvalidApiKey")
		end)
		Framework.it("maps code 17 -> AuthForbidden", function()
			Framework.expect(Errors.FromApiCode(17, "x").Kind).toBe("AuthForbidden")
		end)
		Framework.it("maps transient codes (2, 8, 11, 16) -> Transient", function()
			for _, code in { 2, 8, 11, 16 } do
				Framework.expect(Errors.FromApiCode(code, "x").Kind).toBe("Transient")
			end
		end)
		Framework.it("maps code 29 -> RateLimited", function()
			Framework.expect(Errors.FromApiCode(29, "x").Kind).toBe("RateLimited")
		end)
		Framework.it("unknown codes fall back to ApiError", function()
			Framework.expect(Errors.FromApiCode(999, "x").Kind).toBe("ApiError")
		end)
	end)

	Framework.describe("Errors.IsRetryable", function()
		Framework.it("Transient is retryable", function()
			Framework.expect(Errors.IsRetryable(Errors.New("Transient", "x"))).toBeTruthy()
		end)
		Framework.it("RateLimited is retryable", function()
			Framework.expect(Errors.IsRetryable(Errors.New("RateLimited", "x"))).toBeTruthy()
		end)
		Framework.it("AuthRequired is NOT retryable", function()
			Framework.expect(Errors.IsRetryable(Errors.New("AuthRequired", "x"))).toBeFalsy()
		end)
		Framework.it("InvalidApiKey is NOT retryable", function()
			Framework.expect(Errors.IsRetryable(Errors.New("InvalidApiKey", "x"))).toBeFalsy()
		end)
	end)
end
