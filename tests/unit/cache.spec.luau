--!strict
local Framework = require("../Framework")
local Cache = require("../../src/Cache")
local InMemoryCache = require("../../src/Cache/InMemoryCache")

return function()
	Framework.describe("Cache.KeyFor", function()
		Framework.it("produces deterministic key from sorted params", function()
			local k1 = Cache.KeyFor("track.getInfo", { artist = "Daft Punk", track = "One More Time" })
			local k2 = Cache.KeyFor("track.getInfo", { track = "One More Time", artist = "Daft Punk" })
			Framework.expect(k1).toBe(k2)
		end)

		Framework.it("excludes api_key, api_sig, sk, format", function()
			local k1 = Cache.KeyFor("x", { a = "1", api_key = "k", api_sig = "s", sk = "ss", format = "json" })
			local k2 = Cache.KeyFor("x", { a = "1" })
			Framework.expect(k1).toBe(k2)
		end)

		Framework.it("includes user param so distinct users don't collide", function()
			local alice = Cache.KeyFor("track.getInfo", { artist = "A", track = "T", username = "alice" })
			local bob = Cache.KeyFor("track.getInfo", { artist = "A", track = "T", username = "bob" })
			Framework.expect(alice ~= bob).toBeTruthy()
		end)
	end)

	Framework.describe("InMemoryCache", function()
		Framework.it("returns nil on miss", function()
			local c = InMemoryCache.New()
			Framework.expect(c:Get("missing")).toBeNil()
		end)

		Framework.it("returns the stored entry on hit", function()
			local c = InMemoryCache.New()
			c:Set("k", { Body = "value", ExpiresAt = os.clock() + 1000, Method = "x" })
			local got = c:Get("k")
			Framework.expect(got and got.Body).toBe("value")
		end)

		Framework.it("returns nil for expired entries", function()
			local c = InMemoryCache.New()
			c:Set("k", { Body = "v", ExpiresAt = os.clock() - 1, Method = "x" })
			Framework.expect(c:Get("k")).toBeNil()
		end)

		Framework.it("Invalidate(nil) wipes everything", function()
			local c = InMemoryCache.New()
			c:Set("a", { Body = "1", ExpiresAt = os.clock() + 1000, Method = "x" })
			c:Set("b", { Body = "2", ExpiresAt = os.clock() + 1000, Method = "y" })
			c:Invalidate()
			Framework.expect(c:Get("a")).toBeNil()
			Framework.expect(c:Get("b")).toBeNil()
		end)

		Framework.it("Invalidate(prefix) wipes only matching keys", function()
			local c = InMemoryCache.New()
			c:Set("track.getInfo?x", { Body = "1", ExpiresAt = os.clock() + 1000, Method = "track.getInfo" })
			c:Set("user.getInfo?x", { Body = "2", ExpiresAt = os.clock() + 1000, Method = "user.getInfo" })
			c:Invalidate("track.")
			Framework.expect(c:Get("track.getInfo?x")).toBeNil()
			Framework.expect(c:Get("user.getInfo?x") ~= nil).toBeTruthy()
		end)
	end)
end
